# Self-hosted runner config for terminal-ai (Godot). STUB — confirm REPO_NAME + labels,
# fill in images/godot/Dockerfile's toolchain, then add a PAT in apps/terminal-ai.secret.env.
REPO_OWNER=d3vkit
REPO_NAME=terminal-ai     # TODO: confirm the actual repo name
STACK=godot
RUNNER_LABELS=self-hosted,linux,terminal-ai
RUNNER_NAME=terminal-ai-mac-runner
# Lighter ceilings than the Rails defaults (expo/godot jobs run no Chromium system specs or
# postgres service, so they need less; leaves more of the shared VM for the Rails pairs).
DIND_MEM=1g
RUNNER_MEM=2g
DIND_CPUS=1
RUNNER_CPUS=1.5
