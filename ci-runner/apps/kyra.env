# Self-hosted runner config for kyra_api (Rails).
# PAT goes in apps/kyra.secret.env (gitignored): cp apps/secret.env.example apps/kyra.secret.env
REPO_OWNER=d3vkit
REPO_NAME=kyra_api
STACK=rails
RUNNER_LABELS=self-hosted,linux,kyra
RUNNER_NAME=kyra-mac-runner
# One pair by default: two Rails pairs let a single kyra PR run two heavy jobs at once,
# doubling this app's draw on the shared Docker VM (a top contributor to the "lost
# communication" starvation). Raise only after the VM is given more RAM. `up`/`reset`
# still accept an explicit N to override.
CI_RUNNER_REPLICAS=1
