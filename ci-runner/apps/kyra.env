# Self-hosted runner config for kyra_api (Rails).
# PAT goes in apps/kyra.secret.env (gitignored): cp apps/secret.env.example apps/kyra.secret.env
REPO_OWNER=d3vkit
REPO_NAME=kyra_api
STACK=rails
RUNNER_LABELS=self-hosted,linux,kyra
RUNNER_NAME=kyra-mac-runner
# Two pairs. The old warning here — that two Rails pairs double kyra's draw on the shared
# VM — was correct, and it is answered by kyra_api's ci.yml gaining a
# `concurrency: cancel-in-progress` group in the same change. Without a concurrency group
# the single pair WAS the de-facto serializer for the whole repo; with one, superseded
# runs cancel and the serializer moves to the right layer. That frees far more real VM
# load than any ceiling trim, because ceilings do not reserve.
# Pinned here, not conjured with `up 2`: `reset` with no N re-reads this pin and would
# silently drop back to one pair.
CI_RUNNER_REPLICAS=2

# kyra is the ONLY app that opts out of --ephemeral. Per-job cleanliness moves to
# ACTIONS_RUNNER_HOOK_JOB_STARTED. Every other app keeps today's behaviour by default,
# so a rebuilt shared image is a behavioural no-op for pamm/postcard/ephemeral.
RUNNER_EPHEMERAL=0

# STEP 1 of the cutover: report only. Read the first job's "Set up runner" section and
# confirm the container list does NOT contain this job's own postgres/redis. Then change
# to `full` and `bin/ci-runner kyra up 2` again. Leave this line in place afterwards as a
# documented kill-switch.
CI_RUNNER_SCRUB_MODE=report

# Only ceiling changed. Measured on the live pair: kyra dind cgroup memory.peak over 4
# uninterrupted days = 1385 MiB with oom_kill 0, across a window that included real
# supabase-parity runs — 2.2x margin at 3g. NOT generalised to the compose default:
# pamm's dind peak is 2621 MiB, so the 5g default must stay for everyone else.
# RUNNER_MEM / RUNNER_CPUS / DIND_CPUS are deliberately left at the defaults — see the
# capacity note in ci-runner/README.md.
DIND_MEM=3g
