# Self-hosted runner config for cooldown (Expo/RN). STUB — confirm REPO_NAME + labels,
# fill in images/expo/Dockerfile's toolchain, then add a PAT in apps/cooldown.secret.env.
REPO_OWNER=d3vkit
REPO_NAME=cooldown        # TODO: confirm the actual repo name
STACK=expo
RUNNER_LABELS=self-hosted,linux,cooldown
RUNNER_NAME=cooldown-mac-runner
# Lighter ceilings than the Rails defaults (expo/godot jobs run no Chromium system specs or
# postgres service, so they need less; leaves more of the shared VM for the Rails pairs).
DIND_MEM=1g
RUNNER_MEM=2g
DIND_CPUS=1
RUNNER_CPUS=1.5
