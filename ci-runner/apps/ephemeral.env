# Self-hosted runner config for ephemeral (Godot 4.6; GitHub repo d3vkit/ephemeral).
# PAT in apps/ephemeral.secret.env (gitignored). ci.yml targets [self-hosted, linux, ephemeral].
# The app's ci.yml installs the headless Godot binary itself (arch-aware), so the godot
# image only needs base tooling (curl/unzip) + any headless runtime libs.
REPO_OWNER=d3vkit
REPO_NAME=ephemeral
STACK=godot
RUNNER_LABELS=self-hosted,linux,ephemeral
RUNNER_NAME=ephemeral-mac-runner
