#!/usr/bin/env bash
# Self-hosted GitHub Actions runners for harness apps. Builds a per-stack image once
# (base → stack), then runs N parallel runner+dind pairs registered to an app's repo.
#
#   bin/ci-runner <app> up [N]      # build + start N pairs (default 1, or $CI_RUNNER_REPLICAS)
#   bin/ci-runner <app> down        # stop + remove all of <app>'s pairs
#   bin/ci-runner <app> status      # status of <app>'s pairs
#   bin/ci-runner <app> logs [i]    # follow logs for pair i (default 1)
#
# <app> resolves apps/<app>.env (REPO_OWNER, REPO_NAME, STACK, RUNNER_LABELS,
# RUNNER_NAME). The PAT comes from apps/<app>.secret.env (gitignored) or $GITHUB_PAT.
# See ci-runner/README.md and docs/runbooks/self-hosted-ci-runner.md.
set -euo pipefail

DIR="$(cd "$(dirname "$0")/.." && pwd)"   # ci-runner/
COMPOSE="$DIR/compose.yaml"

usage() {
  cat <<'USAGE'
Usage: bin/ci-runner <app> <command> [args]

Commands:
  <app> up [N]     Build base+stack image once, then start N runner pairs (default 1)
  <app> reset [N]  Down, clear this app's stale GitHub registrations, then up N (clean recovery)
  <app> down       Stop + remove all of <app>'s runner pairs
  <app> status     Show status of <app>'s pairs
  <app> logs [i]   Follow logs for pair i (default 1)
  help             Show this help

<app> is the basename of a file in apps/ (e.g. `kyra` → apps/kyra.env). Size N to
Docker Desktop RAM (each pair carries its own dind + the job's containers).

Environment:
  SKIP_IMAGE_BUILD=1    Reuse the existing harness-runner:<stack> image instead of
                        rebuilding. Use when the base rebuild can't reach the registry
                        (flaky NAT on `FROM ubuntu:…`) but the prior image is still good:
                          SKIP_IMAGE_BUILD=1 bin/ci-runner <app> reset
  CI_RUNNER_REPLICAS=N  Default pair count when N is omitted (apps/<app>.env may pin it;
                        kyra is pinned to 1 — an explicit N overrides the pin).

First run for an app:
  cp apps/secret.env.example apps/<app>.secret.env   # set GITHUB_PAT
  bin/ci-runner <app> up
USAGE
}

app="${1:-help}"
case "$app" in help|-h|--help) usage; exit 0 ;; esac
cmd="${2:-status}"

APP_ENV="$DIR/apps/${app}.env"
if [ ! -f "$APP_ENV" ]; then
  echo "❌ No config for '${app}': missing $APP_ENV" >&2
  echo "   Available: $(cd "$DIR/apps" && ls ./*.env 2>/dev/null | sed 's#.*/##; s/\.env$//' | tr '\n' ' ')" >&2
  exit 1
fi

# Load app config (+ its gitignored secret, if present), exporting for compose/build.
set -a
# shellcheck disable=SC1090
. "$APP_ENV"
# shellcheck disable=SC1090
[ -f "$DIR/apps/${app}.secret.env" ] && . "$DIR/apps/${app}.secret.env"
set +a

: "${REPO_OWNER:?apps/${app}.env must set REPO_OWNER}"
: "${REPO_NAME:?apps/${app}.env must set REPO_NAME}"
: "${STACK:?apps/${app}.env must set STACK (rails|expo|godot)}"
: "${RUNNER_LABELS:?apps/${app}.env must set RUNNER_LABELS}"
prefix="${RUNNER_NAME:-${app}-runner}"
export RUNNER_NAME="$prefix"            # default for down/status; overridden per-pair on up
export RUNNER_IMAGE="harness-runner:${STACK}"

project_base="${app}-runner"
compose_p() { local p="$1"; shift; docker compose -p "$p" -f "$COMPOSE" "$@"; }
list_projects() {
  docker ps -a --format '{{.Label "com.docker.compose.project"}}' 2>/dev/null \
    | grep -E "^${project_base}(-[0-9]+)?$" | sort -u || true   # empty match: not fatal under set -e/pipefail
}

# Disk-reaper heartbeat. The failure that fills the disk is not "the reaper errored" — it
# is "the reaper silently stopped running", which produces no output at all and is
# invisible until CI dies with PG::DiskFull. So check for the ABSENCE of a recent run from
# somewhere people already look. Deliberately NOT called from `reset`: that is the mandated
# recovery path and must not grow new failure modes (VEN-1305).
reaper_heartbeat() {
  local f="${HOME:-}/.local/state/harness-reap/last-run.json" age
  [ -n "${HOME:-}" ] || return 0
  if [ ! -f "$f" ]; then
    echo "⚠️  Docker disk reaper has never run: script/reap-docker-disk.sh" >&2
    return 0
  fi
  age=$(( ( $(date +%s) - $(stat -f %m "$f" 2>/dev/null || echo 0) ) / 3600 ))
  [ "$age" -gt 48 ] && echo "⚠️  Disk reaper last ran ${age}h ago (expected daily): $f" >&2
  grep -q '"exit_code":0' "$f" 2>/dev/null \
    || echo "⚠️  Disk reaper's last run exited non-zero — see ~/Library/Logs/harness/reap-docker-disk.log" >&2
  grep -q '"free_pct":"unknown"' "$f" 2>/dev/null \
    && echo "⚠️  Disk reaper could not read VM headroom — unknown, not healthy." >&2
  return 0
}

# An app that opted out of --ephemeral needs a hook file that only exists in a rebuilt
# image. SKIP_IMAGE_BUILD=1 is the documented recovery path and reuses the OLD image, so
# the flag would be silently ignored. Warn rather than fail: the pair still runs jobs.
warn_on_image_flag_skew() {
  case "${RUNNER_EPHEMERAL:-1}" in 0|false|no) ;; *) return 0 ;; esac
  if ! docker run --rm --entrypoint test "$RUNNER_IMAGE" -f /home/runner/hooks/job-started.sh 2>/dev/null; then
    echo "⚠️  ${app}: RUNNER_EPHEMERAL=0 but ${RUNNER_IMAGE} has no hooks/job-started.sh." >&2
    echo "   The runner will fall back to boot-only cleanup. Rebuild without SKIP_IMAGE_BUILD=1." >&2
  fi
  return 0
}

build_images() {
  # Escape hatch: reuse the existing ${RUNNER_IMAGE} without rebuilding. Lets you
  # recover/start runners when the base rebuild can't reach the registry (flaky NAT
  # on `FROM ubuntu:…`) while the prior image is still valid.
  if [ "${SKIP_IMAGE_BUILD:-0}" = "1" ]; then
    echo "⏭️  SKIP_IMAGE_BUILD=1 — reusing existing ${RUNNER_IMAGE} (no rebuild)."
    return 0
  fi
  echo "🔧 Building harness-runner:base + ${RUNNER_IMAGE}…"
  docker build -t harness-runner:base -f "$DIR/images/base/Dockerfile" "$DIR"
  docker build -t "$RUNNER_IMAGE" --build-arg BASE_IMAGE=harness-runner:base \
    -f "$DIR/images/${STACK}/Dockerfile" "$DIR"
}

# GitHub API via the app's PAT (curl, like entrypoint.sh — no `gh` dependency). Prints the
# response body; returns non-zero on any non-2xx, with the status and body on stderr.
#
# The status check is the point. Plain `curl -sSL` exits 0 for 401/403/404/422 — it only
# fails on transport errors — so an error page flowed downstream as if it were data: jq
# found no `.runners` in it, emitted nothing, and the caller could not tell a dead PAT from
# a repo with nothing to clean.
gh_api() {
  local resp code body
  resp="$(curl -sSL -w $'\n%{http_code}' -H "Authorization: Bearer ${GITHUB_PAT}" \
    -H "Accept: application/vnd.github+json" \
    -H "X-GitHub-Api-Version: 2022-11-28" "$@")" || {
      echo "❌ GitHub API unreachable (curl transport error)." >&2
      return 1
    }
  code="${resp##*$'\n'}"
  body="${resp%$'\n'*}"
  case "$code" in
    2*) printf '%s' "$body"; return 0 ;;
    401) echo "❌ GitHub API 401 — the PAT is invalid or expired." >&2 ;;
    403) echo "❌ GitHub API 403 — the PAT lacks 'Administration: Read and write' on ${REPO_OWNER}/${REPO_NAME}, or is rate-limited." >&2 ;;
    404) echo "❌ GitHub API 404 — ${REPO_OWNER}/${REPO_NAME} not found, or the PAT can't see it." >&2 ;;
    *)   echo "❌ GitHub API ${code:-000}: ${body}" >&2 ;;
  esac
  return 1
}

# Delete this app's runner registrations (name "<prefix>-N") from the repo — clears
# the stale/conflicting sessions a restart or cutover leaves behind.
#
# Errors are handled explicitly rather than left to `set -e`: `reset` calls this as the
# left side of `||`, which suspends errexit for this whole body, so a failing command here
# would otherwise sail on and the function would return 0.
delete_app_runners() {
  local ids id rc=0
  if ! ids="$(gh_api "https://api.github.com/repos/${REPO_OWNER}/${REPO_NAME}/actions/runners?per_page=100" \
    | jq -r --arg p "$prefix" '.runners[]? | select(.name | startswith($p + "-")) | .id')"; then
    echo "   Could not list runners for ${REPO_OWNER}/${REPO_NAME} — nothing was cleared." >&2
    return 1
  fi
  [ -n "$ids" ] || { echo "  no stale ${prefix}-* registrations to clear."; return 0; }
  for id in $ids; do
    # Gate the success line on the actual 204 — a refused DELETE used to print
    # "cleared registration N" regardless, which was simply untrue.
    if gh_api -X DELETE "https://api.github.com/repos/${REPO_OWNER}/${REPO_NAME}/actions/runners/${id}" >/dev/null; then
      echo "  cleared registration ${id}"
    else
      echo "  ⚠️  could not clear registration ${id}" >&2
      rc=1
    fi
  done
  return "$rc"
}

# Start N pairs with unique runner names. Callers build the image first — never from in
# here, so a network-dependent build can never fail *after* a teardown (VEN-1305).
start_pairs() {
  local n="$1" i
  echo "🚀 ${app}: starting $n runner pair(s) [${prefix}-1..$n] → ${REPO_OWNER}/${REPO_NAME} [${RUNNER_LABELS}]"
  for i in $(seq 1 "$n"); do
    export RUNNER_NAME="${prefix}-${i}"
    compose_p "${project_base}-${i}" up -d
  done
}

case "$cmd" in
  up)
    : "${GITHUB_PAT:?Set GITHUB_PAT in apps/${app}.secret.env or the environment}"
    reaper_heartbeat || true
    N="${3:-${CI_RUNNER_REPLICAS:-1}}"
    if ! [[ "$N" =~ ^[0-9]+$ ]] || [ "$N" -lt 1 ]; then echo "up <N>: N must be a positive integer" >&2; exit 2; fi
    build_images
    warn_on_image_flag_skew || true
    start_pairs "$N"
    echo "ℹ️  Each pair runs its own dind + the job's containers — size N to Docker Desktop RAM."
    ;;
  reset)
    # Clean recovery after restart/cutover churn: stop pairs, clear stale GitHub
    # registrations (same-name sessions conflict otherwise), then start fresh.
    : "${GITHUB_PAT:?Set GITHUB_PAT in apps/${app}.secret.env or the environment}"
    N="${3:-${CI_RUNNER_REPLICAS:-1}}"
    if ! [[ "$N" =~ ^[0-9]+$ ]] || [ "$N" -lt 1 ]; then echo "reset <N>: N must be a positive integer" >&2; exit 2; fi
    # Build first, tear down second. build_images reaches the registry (`FROM ubuntu:…`),
    # i.e. it is the step most likely to fail — and the flaky NAT that SKIP_IMAGE_BUILD
    # exists for is exactly when an operator reaches for `reset`. Building after the
    # teardown turned a blip into "all pairs down, all registrations deleted, no image":
    # healthy → zero runners, on the command README documents for a routine scale-down.
    build_images
    echo "🔻 Resetting ${app} runners (down → clear registrations → up $N)…"
    for p in $(list_projects); do echo "🛑 $p"; compose_p "$p" down; done
    echo "🧹 Clearing GitHub registrations for ${prefix}-* on ${REPO_OWNER}/${REPO_NAME}…"
    # Non-fatal past this point: the teardown has already happened, so aborting here would
    # strand the app with zero runners over a cleanup step that `config.sh --replace`
    # largely self-heals anyway. Report and continue to the restart.
    cleared=1
    delete_app_runners || { cleared=0; echo "⚠️  Could not clear registrations; continuing (--replace should reclaim the names)." >&2; }
    sleep 15   # let server-side runner sessions clear before re-registering the same names
    start_pairs "$N"
    # Say only what happened, in both channels. The pairs did start, so we don't abort —
    # but a partial reset must not exit 0: this is the mandated recovery command, and
    # `reset && echo ok` printing ok is the same defect as the ✅ line, just for scripts.
    if [ "$cleared" = 1 ]; then
      echo "✅ ${app}: reset to $N fresh pair(s)."
    else
      echo "⚠️  ${app}: started $N fresh pair(s), but stale registrations were NOT cleared (see above)." >&2
      exit 1
    fi
    ;;
  down)
    projs="$(list_projects)"; [ -z "$projs" ] && { echo "No ${app} runner pairs running."; exit 0; }
    for p in $projs; do echo "🛑 $p"; compose_p "$p" down; done
    ;;
  status|ps)
    reaper_heartbeat || true
    projs="$(list_projects)"; [ -z "$projs" ] && { echo "No ${app} runner pairs running."; exit 0; }
    for p in $projs; do echo "── $p ──"; compose_p "$p" ps; done
    ;;
  logs)
    compose_p "${project_base}-${3:-1}" logs -f runner
    ;;
  *)
    echo "Unknown command: $cmd" >&2; usage >&2; exit 2 ;;
esac
